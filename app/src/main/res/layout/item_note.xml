<?xml version="1.0" encoding="utf-8"?>
<!--
    A single row in the notes list.
    Wrapped in MaterialCardView for visual separation + ripple feedback on tap.

    Layout:
      ┌────────────────────────────────────────────┐
      │  Title (bold, single line, ellipsized)     │
      │  Preview (regular, up to 2 lines)          │
      │  Timestamp (small, accent color)           │
      └────────────────────────────────────────────┘

    Background: `palette_dark_olive` (#3E4512). Text colors are picked from the rest
    of the palette so they read against that dark surface:
      - Title:     palette_sage        — top hierarchy via weight/size, palette-cohesive
      - Preview:   palette_sage        — same color as title; hierarchy comes from size
      - Timestamp: palette_chartreuse  — small accent, ties to the FAB / selection stroke

    Sizes are all `sp`, so they continue to scale with the phone's font-size setting.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:checkable="true"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/palette_dark_olive"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:checkedIconTint="?attr/colorSecondary"
    app:strokeColor="@color/card_stroke_color"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!--
            Note title. textAppearanceTitleMedium gives us Material's font family +
            tracking; we override `textSize` and `textColor` to dial in our own size +
            palette-specific color.
        -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/palette_sage"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="Grocery list" />

        <!--
            First non-blank line of the note body. Hidden when content is empty.
            Two-line cap so a chunkier first sentence still produces a useful preview.
        -->
        <TextView
            android:id="@+id/preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/palette_sage"
            android:textSize="17sp"
            tools:text="Eggs, bread, milk" />

        <!--
            "5 minutes ago" / "yesterday" / "Mar 12". Uses the chartreuse accent so
            it visually deprioritizes vs. the title/preview while still hitting AA
            contrast against dark olive.
        -->
        <TextView
            android:id="@+id/timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/palette_chartreuse"
            android:textSize="13sp"
            tools:text="5 minutes ago" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
