<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        App theme.
        Parent is `Theme.MaterialComponents.DayNight.NoActionBar`:
          - "MaterialComponents" gives us Material widgets and styling.
          - "DayNight" auto-switches between light and dark mode based on the system setting.
          - "NoActionBar" removes the default top bar (a.k.a. ActionBar / app bar) so the
            activity renders edge-to-edge with no title strip at the top.
        If we ever want a top bar back, change this parent to `...DayNight.DarkActionBar`
        (or add our own Toolbar inside the layout for custom control).
    -->
    <style name="Theme.Projectophelia" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color — used by Material widgets like the Button background tint. -->
        <item name="colorPrimary">@color/purple_500</item>
        <!-- Darker variant of the primary, used for the status bar (see below). -->
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <!-- Color for text/icons drawn on top of `colorPrimary` (must contrast with it). -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary accent color — used for things like switches, FAB, highlights. -->
        <item name="colorSecondary">@color/teal_200</item>
        <!-- Darker variant of the secondary. -->
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <!-- Color for text/icons drawn on top of `colorSecondary`. -->
        <item name="colorOnSecondary">@color/black</item>
        <!--
            Tints the system status bar (the strip at the very top showing time/battery).
            `tools:targetApi="l"` silences a lint warning: this attribute only takes effect
            on API 21+ (Lollipop), and our minSdk is 26 so we're safely above that.
        -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <!--
        Toolbar title style.

        Why a custom style? The MaterialToolbar default is `TextAppearance.MaterialComponents.Headline6`
        (20sp), which feels small as a screen-title. We bump the baseline to 26sp.

        Why `sp` (and not `dp`)? `sp` ("scale-independent pixels") multiplies by the user's
        font-scale preference — i.e. it follows the phone's Settings → Display → Font size
        slider. Bumping the phone's font size to "Large" makes our title scale up too;
        switching to "Small" scales it down. `dp` would ignore that setting and look the
        same regardless.

        textColor is already set on the Toolbar itself via `app:titleTextColor`, so we don't
        need to repeat it here.
    -->
    <style name="TextAppearance.Notes.ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <!--
            letterSpacing 0 overrides the parent's slight tracking — denser, more
            "screen-name-y" feel than the parent's airy headline tracking.
        -->
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
