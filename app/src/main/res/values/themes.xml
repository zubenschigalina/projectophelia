<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        App theme. NoActionBar variant because we use our own MaterialToolbar inside
        the layout. DayNight is kept as the parent so dark-mode users still get a
        sensible system rendering — but we do not (yet) provide values-night/ overrides
        for the palette swatches, so the same olive scheme applies in both modes.

        Color attribute mapping to the Notes App palette:
          colorPrimary          → olive (toolbar bg)
          colorPrimaryVariant   → dark olive (status bar)
          colorOnPrimary        → white (toolbar text/icons)
          colorSecondary        → chartreuse (FAB, selection accent)
          colorSecondaryVariant → olive
          colorOnSecondary      → dark olive (icon on chartreuse FAB; high contrast)
          windowBackground      → sage (page background — cards float on this)
    -->
    <style name="Theme.Projectophelia" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary palette -->
        <item name="colorPrimary">@color/palette_olive</item>
        <item name="colorPrimaryVariant">@color/palette_dark_olive</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary palette -->
        <item name="colorSecondary">@color/palette_chartreuse</item>
        <item name="colorSecondaryVariant">@color/palette_olive</item>
        <item name="colorOnSecondary">@color/palette_dark_olive</item>

        <!--
            windowBackground paints the activity itself. Cards (MaterialCardView) draw
            with `colorSurface` (defaults to white in DayNight light mode), which gives
            them clear separation from this sage page background.
        -->
        <item name="android:windowBackground">@color/palette_sage</item>

        <!--
            Tints the system status bar (the strip showing time/battery). Using the
            darkest swatch keeps it visually anchored and provides max contrast for
            white system icons.
            tools:targetApi="l" silences a lint warning — the attribute only applies on
            API 21+, and our minSdk is 26, so we're safely past that threshold.
        -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <!--
        Toolbar title style.
        - 26sp baseline → noticeably big as a screen title.
        - `sp` units → scales with the user's Settings → Display → Font size slider.
        - letterSpacing 0 → denser feel than the default Headline letter spacing.
        textColor is set per-toolbar via `app:titleTextColor`, so we don't repeat it here.
    -->
    <style name="TextAppearance.Notes.ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
