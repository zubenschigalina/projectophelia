<!--
    "+" icon used by the FloatingActionButton on the list screen.

    Tint = ?attr/colorOnSecondary → renders dark olive on the chartreuse FAB. (The
    other toolbar icons use colorOnPrimary because they sit on the olive toolbar; the
    FAB sits on colorSecondary so it gets the matching "on" color.)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorOnSecondary">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M19,13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
</vector>
