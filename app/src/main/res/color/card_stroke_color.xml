<?xml version="1.0" encoding="utf-8"?>
<!--
    Stroke color for note cards. State-aware: chartreuse when the card is `checked`
    (selected), transparent otherwise. The chartreuse accent ties the selected-card
    visual to the FAB color so both "interactive" surfaces share the same hue.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:color="?attr/colorSecondary" />
    <item android:color="@android:color/transparent" />
</selector>
